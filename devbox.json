{
	"$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.3/.schema/devbox.schema.json",
	"packages": {
		"gotools": "0.44.0",
		"gofumpt": "0.10.0",
		"golines": "0.15.0",
		"nixfmt": "1.3.1",
		"gopls": "0.22.0",
		"just": "1.53.0",
		"go": "1.26.3",
		"nixd": "2.9.1",
		"golangci-lint": "2.12.2",
		"golangci-lint-langserver": "0.0.12",
		"just-lsp": "0.4.7",
		"clang-tools": "21.1.8",
		"pkg-config": {
			"version": "0.29.2",
			"platforms": ["x86_64-linux", "aarch64-linux"]
		},
		"cairo": {
			"version": "1.18.4",
			"platforms": ["x86_64-linux", "aarch64-linux"]
		},
		"wayland": {
			"version": "1.22.0",
			"platforms": ["x86_64-linux", "aarch64-linux"]
		},
		"xorg.libX11": {
			"version": "1.8.12",
			"platforms": ["x86_64-linux", "aarch64-linux"]
		},
		"xorg.libXrender": {
			"version": "0.9.12",
			"platforms": ["x86_64-linux", "aarch64-linux"]
		},
		"xorg.libXext": {
			"version": "1.3.6",
			"platforms": ["x86_64-linux", "aarch64-linux"]
		},
		"xorg.libXtst": {
			"version": "1.2.5",
			"platforms": ["x86_64-linux", "aarch64-linux"]
		},
		"xorg.libXrandr": {
			"version": "1.5.4",
			"platforms": ["x86_64-linux", "aarch64-linux"]
		},
		"xorg.libXinerama": {
			"version": "1.1.5",
			"platforms": ["x86_64-linux", "aarch64-linux"]
		},
		"xorg.libXfixes": {
			"version": "6.0.1",
			"platforms": ["x86_64-linux", "aarch64-linux"]
		},
		"libxkbcommon": {
			"version": "1.13.1",
			"platforms": ["x86_64-linux", "aarch64-linux"]
		},
		"wayland-protocols": {
			"version": "1.33",
			"platforms": ["x86_64-linux", "aarch64-linux"]
		},
		"xorg.libXi": {
			"version": "1.8.2",
			"platforms": ["x86_64-linux", "aarch64-linux"]
		}
	},
	"shell": {
		"init_hook": [
			"if [[ \"$(uname)\" == \"Linux\" ]]; then export PKG_CONFIG_PATH_FOR_TARGET=\"$(find /nix/store -maxdepth 5 -type d -name pkgconfig 2>/dev/null | tr '\\n' ':')\" && export CGO_CFLAGS=\"-I$(pkg-config --variable=includedir cairo) $(pkg-config --cflags xi) $CGO_CFLAGS\"; fi"
		]
	}
}
